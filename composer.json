{
    "name": "drupal/legacy-project",
    "description": "Project template for Drupal 9 projects with composer following drupal/drupal layout",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "homepage": "https://www.drupal.org/project/drupal",
    "support": {
        "docs": "https://www.drupal.org/docs/user_guide/en/index.html",
        "chat": "https://www.drupal.org/node/314178"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        }
    ],
    "require": {
        "composer/installers": "^1.2",
        "cweagans/composer-patches": "^1.6",
        "drupal/address": "^1.7",
        "drupal/addtoany": "^2.0",
        "drupal/admin_toolbar": "^3.1",
        "drupal/adminimal_theme": "^1.3",
        "drupal/asset_injector": "^2.6",
        "drupal/better_exposed_filters": "^6.0",
        "drupal/block_exclude_pages": "^2.1@beta",
        "drupal/captcha": "^2.0",
        "drupal/conditional_fields": "^4.0@alpha",
        "drupal/content_access": "^2.0",
        "drupal/core": "^10",
        "drupal/core-composer-scaffold": "^10",
        "drupal/core-project-message": "^10",
        "drupal/csv_serialization": "^3.0 || ^4.0",
        "drupal/devel": "^5.0",
        "drupal/dynamic_entity_reference": "^3.0",
        "drupal/easy_breadcrumb": "^2.0",
        "drupal/editor_advanced_link": "^2.2",
        "drupal/entity_browser": "^2.9",
        "drupal/entity_clone": "^2.0@beta",
        "drupal/entity_reference_revisions": "^1.7",
        "drupal/extlink": "^1.1",
        "drupal/field_group": "^3.0",
        "drupal/field_permissions": "^1.0@RC",
        "drupal/file_delete": "^2.0",
        "drupal/fivestar": "^1.0@alpha",
        "drupal/flag": "^4.0@beta",
        "drupal/focal_point": "^2.0",
        "drupal/fontyourface": "^4.0",
        "drupal/fraction": "^2.0",
        "drupal/geocoder": "^3.20 || ^4.0",
        "drupal/geofield": "^1.55",
        "drupal/geofield_map": "^3.0",
        "drupal/geolocation": "^3.12",
        "drupal/google_analytics": "^4.0",
        "drupal/google_fonts_api": "^3.2",
        "drupal/imce": "^3.0",
        "drupal/jquery_ui": "^1.4",
        "drupal/jquery_ui_accordion": "^2",
        "drupal/jquery_ui_datepicker": "^2.0",
        "drupal/jquery_ui_slider": "^2.0",
        "drupal/jquery_ui_tabs": "^2.0",
        "drupal/jquery_ui_tooltip": "^2.0",
        "drupal/jquery_ui_touch_punch": "^1.1",
        "drupal/linkit": "^6.0",
        "drupal/mailsystem": "^4.3",
        "drupal/masquerade": "^2.0@RC",
        "drupal/menu_breadcrumb": "^2.0@alpha",
        "drupal/menu_item_extras": "^3.0",
        "drupal/menu_link_attributes": "^1.0",
        "drupal/metatag": "^1.26",
        "drupal/mimemail": "^1.0@alpha",
        "drupal/module_filter": "^4.0",
        "drupal/paragraphs": "^1.16",
        "drupal/pathauto": "^1.8",
        "drupal/quick_node_clone": "^1.14",
        "drupal/r4032login": "^2.0",
        "drupal/rabbit_hole": "^1.0@beta",
        "drupal/recaptcha": "^3.2",
        "drupal/recently_read": "^1.0",
        "drupal/redirect": "^1.9",
        "drupal/redirect_after_login": "^3.0",
        "drupal/rules": "^3.0@alpha",
        "drupal/salesforce": "^5.0",
        "drupal/simplenews": "^4.0@alpha",
        "drupal/smtp": "^1.2",
        "drupal/superfish": "^1.6",
        "drupal/swiftmailer": "^2.0",
        "drupal/token": "^1.12",
        "drupal/typed_data": "^1.0@alpha",
        "drupal/upgrade_status": "^4.0",
        "drupal/video_embed_field": "^2.2",
        "drupal/views_accordion": "^2.0",
        "drupal/views_data_export": "^1.4",
        "drupal/views_slideshow": "^5.0",
        "drupal/votingapi": "^3.0@beta",
        "drupal/webform": "^6.2",
        "drupal/webform_score": "^2.0.0-alpha1",
        "drupal/webform_views": "^5.2",
        "drupal/webform_xlsx_export": "^1.2",
        "drush/drush": "^11.6",
        "guzzlehttp/guzzle": "^6.5.2 || ^7.4.1",
        "politsin/jquery-ui-touch-punch": "^1.0"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "discard-changes": true,
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true,
            "cweagans/composer-patches": true,
            "drupal/console-extend-plugin": true,
            "drupal/core-composer-scaffold": true,
            "drupal/core-project-message": true
        }
    },
    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "web/"
            },
            "file-mapping": {
                "[web-root]/.htaccess": false,
                "[web-root]/robots.txt": false
            }
        },
        "patches": {
            "drupal/entity_clone.module": {
                "Entity clone": "https://www.drupal.org/files/issues/2020-05-14/2784373_13.patch"
            },
            "drupal/menu_item_extras": {
                "Menu Items Extras": "https://www.drupal.org/files/issues/2020-04-22/3061342-07-not-found-plugin_0.patch"
            },
            "drupal/cacheflush_cron": {
                "Cache flush Cron": "https://www.drupal.org/files/issues/2019-06-03/cacheflush_cron_fix_preset_name_-3052418-3.patch"
            },
            "drupal/draggableviews": {
                "Draggableviews": "https://www.drupal.org/files/issues/2021-10-11/not_working_with_group_by-draggableviews-2867348-48.patch"
            },
            "drupal/empty_page": {
                "empty_page": "https://www.drupal.org/files/issues/2022-06-15/empty_page.3.0.rector.patch"
            },
            "drupal/views_term_hierarchy_weight_field": {
                "views_term_hierarchy_weight_field": "https://www.drupal.org/files/issues/2022-06-16/views_term_hierarchy_weight_field.1.x-dev.rector.patch"
            },
            "drupal/webform_mass_email": {
                "webform_mass_email": "https://www.drupal.org/files/issues/2022-06-16/webform_mass_email.1.x-dev.rector.patch"
            }
        },
        "installer-paths": {
            "web/core": [
                "type:drupal-core"
            ],
            "web/libraries/{$name}": [
                "type:drupal-library"
            ],
            "web/modules/contrib/{$name}": [
                "type:drupal-module"
            ],
            "web/profiles/contrib/{$name}": [
                "type:drupal-profile"
            ],
            "web/themes/contrib/{$name}": [
                "type:drupal-theme"
            ],
            "drush/Commands/contrib/{$name}": [
                "type:drupal-drush"
            ],
            "web/modules/custom/{$name}": [
                "type:drupal-custom-module"
            ],
            "web/themes/custom/{$name}": [
                "type:drupal-custom-theme"
            ]
        },
        "drupal-core-project-message": {
            "include-keys": [
                "homepage",
                "support"
            ],
            "post-create-project-cmd-message": [
                "<bg=blue;fg=white>                                                         </>",
                "<bg=blue;fg=white>  Congratulations, you’ve installed the Drupal codebase  </>",
                "<bg=blue;fg=white>  from the drupal/recommended-project template!          </>",
                "<bg=blue;fg=white>                                                         </>",
                "",
                "<bg=yellow;fg=black>Next steps</>:",
                "  * Install the site: https://www.drupal.org/docs/8/install",
                "  * Read the user guide: https://www.drupal.org/docs/user_guide/en/index.html",
                "  * Get support: https://www.drupal.org/support",
                "  * Get involved with the Drupal community:",
                "      https://www.drupal.org/getting-involved",
                "  * Remove the plugin that prints this message:",
                "      composer remove drupal/core-project-message"
            ]
        }
    }
}
